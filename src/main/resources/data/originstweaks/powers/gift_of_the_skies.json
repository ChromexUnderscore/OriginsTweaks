	"vanilla_wings": {
		"type": "origins:elytra_flight",
		"render_elytra": true,
		"condition": {
			"type": "origins:origin",
			"layer": "originstweaks:elytrian_options",
			"origin": "originstweaks:vanilla_elytra"
		}
	},
	"custom_wings": {
		"type": "origins:elytra_flight",
		"render_elytra": true,
		"texture_location": "originstweaks:textures/entity/wings.png",
		"condition": {
			"type": "origins:origin",
			"layer": "originstweaks:elytrian_options",
			"origin": "originstweaks:custom_wings"
		}
	},
	"no_render": {
		"type": "origins:elytra_flight",
		"render_elytra": false,
		"condition": {
			"type": "origins:origin",
			"layer": "originstweaks:elytrian_options",
			"origin": "originstweaks:no_render"
		}
	},
	"ascend": {
		"type": "origins:active_self",
		"entity_action": {
			"type": "origins:if_else_list",
			"actions": [
				{
					"condition": {
						"type": "origins:and",
						"conditions": [
							{
								"type": "origins:command",
								"command": "attribute @s minecraft:generic.armor get",
								"comparison": "<=",
								"compare_to": 12
							},
							{
								"type": "origins:resource",
								"resource": "*:*_stamina",
								"comparison": "!=",
								"compare_to": 0
							}
						]
					},
					"action": {
						"type": "origins:and",
						"actions": [
							{
								"type": "origins:add_velocity",
								"y": 0.75,
								"z": 0.5,
								"space": "local_horizontal_normalized",
								"operation": "set"
							},
							{
								"type": "origins:change_resource",
								"resource": "*:*_stamina",
								"change": -25,
								"operation": "add"
							},
							{
								"type": "origins:play_sound",
								"sound": "minecraft:entity.phantom.flap",
								"volume": 1,
								"pitch": 2,
								"category": "players"
							},
							{
								"type": "origins:emit_game_event",
								"event": "minecraft:flap"
							},
							{
								"comment": "These two actions adding and removing FlapTrigger are unused tags by default, you may use them in a Figura script to play a wing flap animation with the elytra for example.",
								"type": "origins:execute_command",
								"command": "tag @s add FlapTrigger"
							},
							{
								"type": "origins:delay",
								"ticks": 10,
								"action": {
									"type": "origins:execute_command",
									"command": "tag @s remove FlapTrigger"
								}
							}
						]
					}
				},
				{
					"condition": {
						"type": "origins:and",
						"conditions": [
							{
								"type": "origins:command",
								"command": "attribute @s minecraft:generic.armor get",
								"comparison": ">",
								"compare_to": 12
							},
							{
								"type": "origins:command",
								"command": "attribute @s minecraft:generic.armor get",
								"comparison": "<",
								"compare_to": 20
							},
							{
								"type": "origins:resource",
								"resource": "*:*_stamina",
								"comparison": "!=",
								"compare_to": 0
							}
						]
					},
					"action": {
						"type": "origins:and",
						"actions": [
							{
								"type": "origins:add_velocity",
								"y": 0.5,
								"z": 0.25,
								"space": "local_horizontal_normalized",
								"operation": "set"
							},
							{
								"type": "origins:execute_command",
								"command": "playsound minecraft:entity.phantom.flap player @a ~ ~ ~ 1 2"
							},
							{
								"type": "origins:change_resource",
								"resource": "*:*_stamina",
								"change": -50,
								"operation": "add"
							},
							{
								"type": "origins:emit_game_event",
								"event": "minecraft:flap"
							}
						]
					}
				},
				{
					"condition": {
						"type": "origins:command",
						"command": "attribute @s minecraft:generic.armor get",
						"comparison": ">=",
						"compare_to": 20
					},
					"action": {
						"type": "origins:execute_command",
						"command": "title @s actionbar \"Your armor is too heavy to ascend.\""
					}
				},
				{
					"condition": {
						"type": "origins:resource",
						"resource": "*:*_stamina",
						"comparison": "==",
						"compare_to": 0
					},
					"action": {
						"type": "origins:execute_command",
						"command": "title @s actionbar \"You are too exhausted to ascend.\""
					}
				}
			]
		},
		"cooldown": 20,
		"hud_render": {
			"should_render": false
		},
		"key": {
			"key": "key.origins.primary_active",
			"continuous": true
		},
		"condition": {
			"type": "origins:and",
			"conditions": [
				{
					"type": "origins:on_block",
					"inverted": true
				},
				{
					"type": "origins:fall_flying"
				}
			]
		}
	},
	"skip_takeoff_damage": {
		"type": "origins:modify_damage_taken",
		"damage_condition": {
			"type": "origins:type",
			"damage_type": "minecraft:fly_into_wall"
		},
		"modifier": {
			"name": "skip_takeoff_damage",
			"value": 0,
			"operation": "set_total"
		},
		"condition": {
			"type": "origins:resource",
			"comparison": "!=",
			"compare_to": 0,
			"resource": "*:*_takeoff_timer"
		}
	},
	"takeoff_timer": {
		"type": "origins:cooldown",
		"cooldown": 20
	},
	"takeoff_timer_check": {
		"type": "origins:action_over_time",
		"interval": 1,
		"rising_action": {
			"type": "origins:trigger_cooldown",
			"power": "*:*_takeoff_timer"
		},
		"condition": {
			"type": "origins:fall_flying"
		}
	},
	"stamina": {
		"type": "origins:resource",
		"min": 0,
		"max": 600,
		"start_value": 600,
		"hud_render": {
			"sprite_location": "origins:textures/gui/resource_bar.png",
			"bar_index": 2,
			"condition": {
				"type": "origins:resource",
				"resource": "*:*_stamina",
				"compare_to": 600,
				"comparison": "!="
			}
		}
	},
	"stamina_regenerate": {
		"type": "origins:action_over_time",
		"interval": 3,
		"entity_action": {
			"type": "origins:change_resource",
			"resource": "*:*_stamina",
			"change": 6
		},
		"condition": {
			"type": "origins:fall_flying",
			"inverted": true
		}
	},
	"stamina_sleep": {
		"type": "origins:action_on_wake_up",
		"entity_action": {
			"type": "origins:change_resource",
			"resource": "*:*_stamina",
			"change": 600,
			"operation": "set"
		}
	},
	"stamina_respawn": {
		"type": "origins:action_on_callback",
		"entity_action_respawned": {
			"type": "origins:change_resource",
			"resource": "*:*_stamina",
			"change": 600,
			"operation": "set"
		}
	},
	"restrict_fireworks": {
		"type": "origins:prevent_item_use",
		"item_condition": {
			"type": "origins:ingredient",
			"ingredient": {
				"item": "minecraft:firework_rocket"
			}
		},
		"condition": {
			"type": "origins:fall_flying"
		}
	}
}